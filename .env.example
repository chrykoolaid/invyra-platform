APP_NAME=Invyra Platform
APP_ENV=local
DEBUG=false

DATABASE_URL=postgresql+psycopg://invyra:invyra@localhost:5432/invyra_platform
TEST_DATABASE_URL=postgresql+psycopg://invyra:invyra@localhost:5433/invyra_platform_test

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me
SESSION_COOKIE_NAME=invyra_session

SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

PASSWORD_HASH_ALGORITHM=argon2id
DEFAULT_TIMEZONE=Asia/Manila

ENABLE_DEV_SEED=false
ENABLE_TEST_SEED=false
AUDIT_LOGGING_ENABLED=true
LOG_LEVEL=INFO

ALLOW_CRM=false
ALLOW_POS=false
ALLOW_PAYROLL=false
ALLOW_WORKFORCE_MANAGEMENT=false
ALLOW_FORECASTING=false
ALLOW_PURCHASING_EXTENSIONS=false
